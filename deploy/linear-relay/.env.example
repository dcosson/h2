# Copy to .env and fill in. Values come from your published Linear OAuth app.
# The OAuth app's redirect URI must be  <base-url>/oauth/callback
# and its webhook URL must be           <base-url>/webhook

H2_RELAY_BASE_URL=https://relay.example.com
H2_RELAY_CLIENT_ID=
H2_RELAY_CLIENT_SECRET=
H2_RELAY_WEBHOOK_SECRET=
